<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Alexis Paillot — Développeur Web & Coureur de Trail. Portfolio AlpaStudio."
    />

    <link rel="canonical" href="https://alpastudio.fr/" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AlpaStudio" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:url" content="https://alpastudio.fr/" />
    <meta property="og:title" content="Alexis Paillot — AlpaStudio" />
    <meta
      property="og:description"
      content="Développeur Web & Coureur de Trail. Portfolio interactif : compétences, expériences, projets et créations."
    />
    <meta property="og:image" content="https://alpastudio.fr/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Alexis Paillot — AlpaStudio" />
    <meta
      name="twitter:description"
      content="Développeur Web & Coureur de Trail. Portfolio interactif : compétences, expériences, projets et créations."
    />
    <meta name="twitter:image" content="https://alpastudio.fr/og-image.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Public+Sans:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <title inertia>AlpaStudio</title>

    @inertiaHead()
    @vite(['inertia/app/app.ts'])
  </head>
  <body>
    @inertia()
  </body>
</html>
